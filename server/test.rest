# paste tokens + city ids from login/register responses
@tokenAtk = TOKEN_HERE
@tokenDef = TOKEN_HERE
@cityIdAtk = CITY_ID_HERE
@cityIdDef = CITY_ID_HERE

### ========== CITIES ==========

### my cities (attacker)
GET http://localhost:3000/api/cities/mine
Authorization: Bearer {{tokenAtk}}

###

### my cities (defender)
GET http://localhost:3000/api/cities/mine
Authorization: Bearer {{tokenDef}}

###

### rename city
PATCH http://localhost:3000/api/cities/mine/name
Authorization: Bearer {{tokenAtk}}
Content-Type: application/json

{
  "name": "New Athens"
}

###

### ========== MAP ==========

### get map
GET http://localhost:3000/api/map
Authorization: Bearer {{tokenAtk}}

###

### ========== BUILDINGS ==========

### upgrade a building (paste buildingId from GET /cities/mine)
@buildingId = BUILDING_ID_HERE

POST http://localhost:3000/api/buildings/{{buildingId}}/upgrade
Authorization: Bearer {{tokenAtk}}

###

### cancel building upgrade order
@buildingOrderId = ORDER_ID_HERE

DELETE http://localhost:3000/api/buildings/orders/{{buildingOrderId}}
Authorization: Bearer {{tokenAtk}}

###

### ========== RECRUITMENT ==========

### recruit units
POST http://localhost:3000/api/cities/{{cityIdAtk}}/recruit
Authorization: Bearer {{tokenAtk}}
Content-Type: application/json

{
  "unitName": "LIGHT_INFANTRY",
  "quantity": 10
}

###

### cancel recruitment order
@recruitOrderId = ORDER_ID_HERE

DELETE http://localhost:3000/api/buildings/recruitment/orders/{{recruitOrderId}}
Authorization: Bearer {{tokenAtk}}

###

### ========== COMMANDS (ATTACK / SPY / SUPPORT / RESOURCES) ==========

### attack — 100 LI vs empty city
POST http://localhost:3000/api/cities/{{cityIdAtk}}/commands
Authorization: Bearer {{tokenAtk}}
Content-Type: application/json

{
  "type": "ATTACK",
  "targetCityId": "{{cityIdDef}}",
  "units": { "LIGHT_INFANTRY": 100 }
}

###

### spy mission (requires hackers)
POST http://localhost:3000/api/cities/{{cityIdAtk}}/commands
Authorization: Bearer {{tokenAtk}}
Content-Type: application/json

{
  "type": "SPY",
  "targetCityId": "{{cityIdDef}}",
  "units": { "HACKER": 5 }
}

###

### send support
POST http://localhost:3000/api/cities/{{cityIdAtk}}/commands
Authorization: Bearer {{tokenAtk}}
Content-Type: application/json

{
  "type": "SUPPORT",
  "targetCityId": "{{cityIdDef}}",
  "units": { "LIGHT_INFANTRY": 50 }
}

###

### send resources (requires Harbor)
POST http://localhost:3000/api/cities/{{cityIdAtk}}/commands
Authorization: Bearer {{tokenAtk}}
Content-Type: application/json

{
  "type": "RESOURCES",
  "targetCityId": "{{cityIdDef}}",
  "resources": { "money": 100, "energy": 50, "ammo": 0 }
}

###

### withdraw support
POST http://localhost:3000/api/cities/{{cityIdDef}}/commands/withdraw
Authorization: Bearer {{tokenAtk}}
Content-Type: application/json

{
  "units": { "LIGHT_INFANTRY": 10 }
}

###

### list commands
GET http://localhost:3000/api/cities/{{cityIdAtk}}/commands
Authorization: Bearer {{tokenAtk}}

###

### cancel command
@commandId = COMMAND_ID_HERE

POST http://localhost:3000/api/cities/{{cityIdAtk}}/commands/{{commandId}}/cancel
Authorization: Bearer {{tokenAtk}}

