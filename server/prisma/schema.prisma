generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "linux-musl-openssl-3.0.x"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ─── Enums ────────────────────────────────────────────────────────────────────

enum BuildingName {
  HEADQUARTERS
  BANK
  POWER_PLANT
  WEAPONS_FACTORY
  MILITARY_BASE
  HOUSING
  WAREHOUSE
  HARBOR
  AIR_DEFENSE
}

enum UnitName {
  LIGHT_INFANTRY
  DEFENDER_INFANTRY
  HEAVY_INFANTRY
  SNIPER
  SPECIAL_FORCES
  RAIDER
  TANK
  MISSILE_LAUNCHER
  DRONE
  GOVERNOR
  HACKER
}

enum UnitCategory {
  INFANTRY
  RANGE
  MECHANIZED
  SIEGE
  CONQUER
  SPY
}

enum CommandType {
  ATTACK
  SUPPORT
  RESOURCES
  SPY
}

enum CommandStatus {
  TRAVELING
  RETURNING
  ARRIVED
  COMPLETED
}

enum AllianceAccess {
  OPEN
  CLOSED
  INVITE_ONLY
  APPLICATION
}

// ─── Models ───────────────────────────────────────────────────────────────────

model User {
  id        String   @id @default(uuid())
  username  String   @unique
  email     String   @unique
  password  String
  description String?
  avatarUrl   String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Governor recruitment (per cont)
  governorsRecruited Int   @default(0)
  governorMoney      Float @default(0)
  governorEnergy     Float @default(0)
  governorAmmo       Float @default(0)

  // Lifetime combat stats (leaderboard)
  killsAsAttacker  Int   @default(0)
  killsAsDefender  Int   @default(0)
  killsAsSupporter Int   @default(0)
  lootedMoney      Float @default(0)
  lootedEnergy     Float @default(0)
  lootedAmmo       Float @default(0)

  allianceId      String?
  alliance        Alliance? @relation("AllianceMembers", fields: [allianceId], references: [id])
  leadingAlliance Alliance? @relation("AllianceLeader")

  allianceInvitations  AllianceInvitation[] @relation("InviteTarget")
  allianceApplications AllianceApplication[] @relation("ApplicationUser")
  allianceMessages     AllianceMessage[]    @relation("MessageAuthor")
  allianceMessagesReadAt DateTime?

  directMessagesSent     DirectMessage[] @relation("DirectMessageFrom")
  directMessagesReceived DirectMessage[] @relation("DirectMessageTo")

  cities           City[]
  commandsAttacker Command[] @relation("CommandAttacker")
  commandsDefender Command[] @relation("CommandDefender")
  sharedReports    SharedReport[] @relation("SharedReportAuthor")
}

model Alliance {
  id          String         @id @default(uuid())
  name        String         @unique
  tag         String         @unique
  description String?
  avatarUrl   String?
  accessMode  AllianceAccess @default(OPEN)
  createdAt   DateTime       @default(now())
  updatedAt   DateTime       @updatedAt

  leaderId String @unique
  leader   User   @relation("AllianceLeader", fields: [leaderId], references: [id])

  members      User[]                @relation("AllianceMembers")
  invitations  AllianceInvitation[]
  applications AllianceApplication[]
  messages     AllianceMessage[]
}

model AllianceInvitation {
  id         String   @id @default(uuid())
  allianceId String
  alliance   Alliance @relation(fields: [allianceId], references: [id], onDelete: Cascade)
  userId     String
  user       User     @relation("InviteTarget", fields: [userId], references: [id])
  createdAt  DateTime @default(now())

  @@unique([allianceId, userId])
}

model AllianceApplication {
  id         String   @id @default(uuid())
  allianceId String
  alliance   Alliance @relation(fields: [allianceId], references: [id], onDelete: Cascade)
  userId     String
  user       User     @relation("ApplicationUser", fields: [userId], references: [id])
  message    String
  createdAt  DateTime @default(now())

  @@unique([allianceId, userId])
}

model AllianceMessage {
  id         String   @id @default(uuid())
  allianceId String
  alliance   Alliance @relation(fields: [allianceId], references: [id], onDelete: Cascade)
  authorId   String
  author     User     @relation("MessageAuthor", fields: [authorId], references: [id])
  content    String
  createdAt  DateTime @default(now())
  deleted    Boolean  @default(false)

  @@index([allianceId, createdAt])
}

model DirectMessage {
  id         String   @id @default(uuid())
  fromId     String
  from       User     @relation("DirectMessageFrom", fields: [fromId], references: [id])
  toId       String
  to         User     @relation("DirectMessageTo",   fields: [toId],   references: [id])
  content    String
  createdAt  DateTime @default(now())

  // marcam vazut cand destinatarul deschide firul
  readByRecipient Boolean @default(false)

  // soft-delete per-parte: dispare din view-ul celui care a sters, dar celalalt il mai vede
  deletedByFrom Boolean @default(false)
  deletedByTo   Boolean @default(false)

  @@index([fromId, toId, createdAt])
  @@index([toId, fromId, createdAt])
  @@index([toId, readByRecipient])
}

model City {
  id        String   @id @default(uuid())
  name      String
  x         Int
  y         Int
  loyalty   Float    @default(100.0)
  money     Float    @default(1000.0)
  energy    Float    @default(1000.0)
  ammo      Float    @default(1000.0)
  lastResourceUpdate DateTime @default(now())
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  ownerId String?
  owner   User?   @relation(fields: [ownerId], references: [id])

  buildings             Building[]
  units                 Unit[]
  outgoingCommands      Command[]              @relation("CommandFrom")
  incomingCommands      Command[]              @relation("CommandTo")
  buildingUpgradeOrders BuildingUpgradeOrder[]
  recruitmentOrders     RecruitmentOrder[]

  @@unique([x, y])
  @@index([ownerId])
}

model Building {
  id     String       @id @default(uuid())
  name   BuildingName
  level  Int          @default(0)

  cityId String
  city   City   @relation(fields: [cityId], references: [id])

  @@unique([cityId, name])
}

model BuildingUpgradeOrder {
  id           String       @id @default(uuid())
  buildingName BuildingName
  startAt      DateTime
  finishAt     DateTime
  jobId        String?

  cityId String
  city   City   @relation(fields: [cityId], references: [id])

  @@index([cityId])
}

model RecruitmentOrder {
  id       String   @id @default(uuid())
  unitName UnitName
  quantity Int
  startAt  DateTime
  finishAt DateTime
  jobId    String?

  cityId String
  city   City   @relation(fields: [cityId], references: [id])

  @@index([cityId])
}

model Unit {
  id       String       @id @default(uuid())
  name     UnitName
  category UnitCategory
  quantity Int          @default(0)

  cityId String
  city   City   @relation(fields: [cityId], references: [id])

  @@unique([cityId, name])
}

model SharedReport {
  id        String   @id @default(uuid())
  commandId String
  command   Command  @relation(fields: [commandId], references: [id])
  userId    String
  user      User     @relation("SharedReportAuthor", fields: [userId], references: [id])

  hideOwnTroops   Boolean @default(false)
  hideOwnInitial  Boolean @default(false)
  hideEnemyTroops Boolean @default(false)

  createdAt DateTime @default(now())

  @@index([commandId])
}

model Command {
  id          String        @id @default(uuid())
  type        CommandType
  status      CommandStatus @default(TRAVELING)
  departureAt DateTime      @default(now())
  arrivalAt   DateTime

  // resurse trimise (RESOURCES) sau furate (ATTACK return)
  resourceMoney  Float @default(0)
  resourceEnergy Float @default(0)
  resourceAmmo   Float @default(0)

  // cladirea tinta pentru drone (optional, doar ATTACK cu drone)
  targetBuilding BuildingName?

  // raport de lupta (completat dupa sosire, pentru ATTACK)
  report Json?

  // Fiecare parte isi poate "sterge" raportul (ascunde din lista).
  // Cand ambele sunt true, raportul e invizibil pentru toata lumea.
  reportHiddenByAttacker Boolean @default(false)
  reportHiddenByDefender Boolean @default(false)

  fromCityId String
  fromCity   City   @relation("CommandFrom", fields: [fromCityId], references: [id])

  toCityId String
  toCity   City   @relation("CommandTo", fields: [toCityId], references: [id])

  // Proprietarii la momentul crearii raportului. Decuplati de ownerId-ul
  // curent al oraselor — altfel, daca un oras e cucerit ulterior, raportul
  // "schimba" de partea cui e si verificarile de acces/stergere esueaza.
  attackerUserId String
  attacker       User    @relation("CommandAttacker", fields: [attackerUserId], references: [id])
  defenderUserId String?
  defender       User?   @relation("CommandDefender", fields: [defenderUserId], references: [id])

  units         CommandUnit[]
  sharedReports SharedReport[]

  @@index([fromCityId, status])
  @@index([toCityId, type, status])
  @@index([attackerUserId])
  @@index([defenderUserId])
}

model CommandUnit {
  id       String   @id @default(uuid())
  name     UnitName
  quantity Int

  commandId String
  command   Command @relation(fields: [commandId], references: [id])

  @@unique([commandId, name])
}
