generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "linux-musl-openssl-3.0.x"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ─── Enums ────────────────────────────────────────────────────────────────────

enum BuildingName {
  HEADQUARTERS
  BANK
  POWER_PLANT
  WEAPONS_FACTORY
  MILITARY_BASE
  HOUSING
  WAREHOUSE
  HARBOR
  AIR_DEFENSE
}

enum UnitName {
  LIGHT_INFANTRY
  DEFENDER_INFANTRY
  HEAVY_INFANTRY
  SNIPER
  SPECIAL_FORCES
  RAIDER
  TANK
  MISSILE_LAUNCHER
  DRONE
  GOVERNOR
  HACKER
}

enum UnitCategory {
  INFANTRY
  RANGE
  MECHANIZED
  SIEGE
  CONQUER
  SPY
}

enum CommandType {
  ATTACK
  SUPPORT
  RESOURCES
  SPY
}

enum CommandStatus {
  TRAVELING
  RETURNING
  ARRIVED
  COMPLETED
}

enum AllianceAccess {
  OPEN
  CLOSED
  INVITE_ONLY
  APPLICATION
}

enum SiegeStatus {
  ACTIVE
  BROKEN_BY_DEFENSE
  BROKEN_BY_NEW_SIEGE
  COMPLETED_CONQUEST
}

// ─── Models ───────────────────────────────────────────────────────────────────

model User {
  id        String   @id @default(uuid())
  username  String   @unique
  email     String   @unique
  password  String
  description String?
  avatarUrl   String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Governor recruitment (per account)
  governorsRecruited Int   @default(0)
  governorMoney      Float @default(0)
  governorEnergy     Float @default(0)
  governorAmmo       Float @default(0)

  // Lifetime combat stats (leaderboard)
  killsAsAttacker  Int   @default(0)
  killsAsDefender  Int   @default(0)
  killsAsSupporter Int   @default(0)
  lootedMoney      Float @default(0)
  lootedEnergy     Float @default(0)
  lootedAmmo       Float @default(0)

  allianceId      String?
  alliance        Alliance? @relation("AllianceMembers", fields: [allianceId], references: [id])
  leadingAlliance Alliance? @relation("AllianceLeader")

  allianceInvitations  AllianceInvitation[] @relation("InviteTarget")
  allianceApplications AllianceApplication[] @relation("ApplicationUser")
  allianceMessages     AllianceMessage[]    @relation("MessageAuthor")
  allianceMessagesReadAt DateTime?

  directMessagesSent     DirectMessage[] @relation("DirectMessageFrom")
  directMessagesReceived DirectMessage[] @relation("DirectMessageTo")

  cities           City[]
  commandsAttacker Command[] @relation("CommandAttacker")
  commandsDefender Command[] @relation("CommandDefender")
  sharedReports    SharedReport[] @relation("SharedReportAuthor")
  sieges           Siege[]   @relation("SiegeAttacker")
  sharedSieges     SharedSiege[] @relation("SharedSiegeAuthor")
}

model Alliance {
  id          String         @id @default(uuid())
  name        String         @unique
  tag         String         @unique
  description String?
  avatarUrl   String?
  accessMode  AllianceAccess @default(OPEN)
  createdAt   DateTime       @default(now())
  updatedAt   DateTime       @updatedAt

  leaderId String @unique
  leader   User   @relation("AllianceLeader", fields: [leaderId], references: [id])

  members      User[]                @relation("AllianceMembers")
  invitations  AllianceInvitation[]
  applications AllianceApplication[]
  messages     AllianceMessage[]
}

model AllianceInvitation {
  id         String   @id @default(uuid())
  allianceId String
  alliance   Alliance @relation(fields: [allianceId], references: [id], onDelete: Cascade)
  userId     String
  user       User     @relation("InviteTarget", fields: [userId], references: [id])
  createdAt  DateTime @default(now())

  @@unique([allianceId, userId])
}

model AllianceApplication {
  id         String   @id @default(uuid())
  allianceId String
  alliance   Alliance @relation(fields: [allianceId], references: [id], onDelete: Cascade)
  userId     String
  user       User     @relation("ApplicationUser", fields: [userId], references: [id])
  message    String
  createdAt  DateTime @default(now())

  @@unique([allianceId, userId])
}

model AllianceMessage {
  id         String   @id @default(uuid())
  allianceId String
  alliance   Alliance @relation(fields: [allianceId], references: [id], onDelete: Cascade)
  authorId   String
  author     User     @relation("MessageAuthor", fields: [authorId], references: [id])
  content    String
  createdAt  DateTime @default(now())
  deleted    Boolean  @default(false)

  @@index([allianceId, createdAt])
}

model DirectMessage {
  id         String   @id @default(uuid())
  fromId     String
  from       User     @relation("DirectMessageFrom", fields: [fromId], references: [id])
  toId       String
  to         User     @relation("DirectMessageTo",   fields: [toId],   references: [id])
  content    String
  createdAt  DateTime @default(now())

  // mark as seen when the recipient opens the thread
  readByRecipient Boolean @default(false)

  // per-party soft-delete: disappears from the view of whoever deleted it, but the other still sees it
  deletedByFrom Boolean @default(false)
  deletedByTo   Boolean @default(false)

  @@index([fromId, toId, createdAt])
  @@index([toId, fromId, createdAt])
  @@index([toId, readByRecipient])
}

model City {
  id        String   @id @default(uuid())
  name      String
  x         Int
  y         Int
  money     Float    @default(1000.0)
  energy    Float    @default(1000.0)
  ammo      Float    @default(1000.0)
  lastResourceUpdate DateTime @default(now())
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  ownerId String?
  owner   User?   @relation(fields: [ownerId], references: [id])

  buildings             Building[]
  units                 Unit[]
  outgoingCommands      Command[]              @relation("CommandFrom")
  incomingCommands      Command[]              @relation("CommandTo")
  buildingUpgradeOrders BuildingUpgradeOrder[]
  recruitmentOrders     RecruitmentOrder[]
  sieges                Siege[]

  @@unique([x, y])
  @@index([ownerId])
}

// Active conquest siege on a city. cityId is UNIQUE — only one active siege at a time
// (the "lock"). When a stronger conquest attack lands while a siege is already active,
// the existing row is updated to BROKEN_BY_NEW_SIEGE and a fresh ACTIVE one is created.
// Historical (non-ACTIVE) sieges are kept for reporting.
model Siege {
  id                String      @id @default(uuid())
  cityId            String
  city              City        @relation(fields: [cityId], references: [id], onDelete: Cascade)
  attackerUserId    String
  attacker          User        @relation("SiegeAttacker", fields: [attackerUserId], references: [id])
  // The SUPPORT-ARRIVED command that holds the besieger's garrison (governor + escort survivors).
  // When this command's units reach 0, the siege auto-breaks (BROKEN_BY_DEFENSE).
  garrisonCommandId String      @unique
  garrisonCommand   Command     @relation("SiegeGarrison", fields: [garrisonCommandId], references: [id])
  startedAt         DateTime    @default(now())
  endsAt            DateTime
  status            SiegeStatus @default(ACTIVE)
  // BullMQ job id for the timer; cleared when siege ends in any way other than expiry.
  jobId             String?

  // Partial unique index enforced via app-level guard + a regular unique on cityId for active rows.
  // Prisma doesn't support partial indexes; we keep ACTIVE-only invariant in code (siege.service).
  @@index([cityId, status])
  @@index([attackerUserId, status])

  sharedLinks SharedSiege[]
}

// A user-generated share link to a siege. Anyone (logged-in) can fetch the siege state by
// the SharedSiege.id. Mirrors SharedReport but for live siege views.
model SharedSiege {
  id        String   @id @default(uuid())
  siegeId   String
  siege     Siege    @relation(fields: [siegeId], references: [id], onDelete: Cascade)
  userId    String
  user      User     @relation("SharedSiegeAuthor", fields: [userId], references: [id])
  createdAt DateTime @default(now())

  @@index([siegeId])
}

model Building {
  id     String       @id @default(uuid())
  name   BuildingName
  level  Int          @default(0)

  cityId String
  city   City   @relation(fields: [cityId], references: [id])

  @@unique([cityId, name])
}

model BuildingUpgradeOrder {
  id           String       @id @default(uuid())
  buildingName BuildingName
  startAt      DateTime
  finishAt     DateTime
  jobId        String?

  cityId String
  city   City   @relation(fields: [cityId], references: [id])

  @@index([cityId])
}

model RecruitmentOrder {
  id       String   @id @default(uuid())
  unitName UnitName
  quantity Int
  startAt  DateTime
  finishAt DateTime
  jobId    String?

  cityId String
  city   City   @relation(fields: [cityId], references: [id])

  @@index([cityId])
}

model Unit {
  id       String       @id @default(uuid())
  name     UnitName
  category UnitCategory
  quantity Int          @default(0)

  cityId String
  city   City   @relation(fields: [cityId], references: [id])

  @@unique([cityId, name])
}

model SharedReport {
  id        String   @id @default(uuid())
  commandId String
  command   Command  @relation(fields: [commandId], references: [id])
  userId    String
  user      User     @relation("SharedReportAuthor", fields: [userId], references: [id])

  hideOwnTroops   Boolean @default(false)
  hideOwnInitial  Boolean @default(false)
  hideEnemyTroops Boolean @default(false)

  createdAt DateTime @default(now())

  @@index([commandId])
}

model Command {
  id          String        @id @default(uuid())
  type        CommandType
  status      CommandStatus @default(TRAVELING)
  departureAt DateTime      @default(now())
  arrivalAt   DateTime

  // resources sent (RESOURCES) or stolen (ATTACK return)
  resourceMoney  Float @default(0)
  resourceEnergy Float @default(0)
  resourceAmmo   Float @default(0)

  // target building for drones (optional, only ATTACK with drones)
  targetBuilding BuildingName?

  // battle report (filled in after arrival, for ATTACK)
  report Json?

  // Each party can "delete" its report (hide it from the list).
  // When both are true, the report is invisible to everyone.
  reportHiddenByAttacker Boolean @default(false)
  reportHiddenByDefender Boolean @default(false)

  fromCityId String
  fromCity   City   @relation("CommandFrom", fields: [fromCityId], references: [id])

  toCityId String
  toCity   City   @relation("CommandTo", fields: [toCityId], references: [id])

  // The owners at the time the report was created. Decoupled from the cities'
  // current ownerId — otherwise, if a city is conquered later, the report would
  // "switch" sides and the access/deletion checks would fail.
  attackerUserId String
  attacker       User    @relation("CommandAttacker", fields: [attackerUserId], references: [id])
  defenderUserId String?
  defender       User?   @relation("CommandDefender", fields: [defenderUserId], references: [id])

  units         CommandUnit[]
  sharedReports SharedReport[]
  sieges        Siege[]        @relation("SiegeGarrison")

  @@index([fromCityId, status])
  @@index([toCityId, type, status])
  @@index([attackerUserId])
  @@index([defenderUserId])
}

model CommandUnit {
  id       String   @id @default(uuid())
  name     UnitName
  quantity Int

  commandId String
  command   Command @relation(fields: [commandId], references: [id])

  @@unique([commandId, name])
}
