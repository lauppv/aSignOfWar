generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ─── Enums ────────────────────────────────────────────────────────────────────

enum BuildingName {
  HEADQUARTERS
  BANK
  POWER_PLANT
  WEAPONS_FACTORY
  MILITARY_BASE
  HOUSING
  WAREHOUSE
  HARBOR
  AIR_DEFENSE
}

enum UnitName {
  LIGHT_INFANTRY
  DEFENDER_INFANTRY
  HEAVY_INFANTRY
  SNIPER
  SPECIAL_FORCES
  RAIDER
  TANK
  MISSILE_LAUNCHER
  DRONE
  GOVERNOR
}

enum UnitCategory {
  INFANTRY
  RANGE
  MECHANIZED
  SIEGE
  CONQUER
}

enum CommandType {
  ATTACK
  SUPPORT
  RESOURCES
}

enum CommandStatus {
  TRAVELING
  RETURNING
  ARRIVED
  COMPLETED
}

// ─── Models ───────────────────────────────────────────────────────────────────

model User {
  id        String   @id @default(uuid())
  username  String   @unique
  email     String   @unique
  password  String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  cities City[]
}

model City {
  id        String   @id @default(uuid())
  name      String
  x         Int
  y         Int
  loyalty   Float    @default(100.0)
  money     Float    @default(1000.0)
  energy    Float    @default(1000.0)
  ammo      Float    @default(1000.0)
  lastResourceUpdate DateTime @default(now())
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  ownerId String?
  owner   User?   @relation(fields: [ownerId], references: [id])

  buildings             Building[]
  units                 Unit[]
  outgoingCommands      Command[]              @relation("CommandFrom")
  incomingCommands      Command[]              @relation("CommandTo")
  buildingUpgradeOrders BuildingUpgradeOrder[]
  recruitmentOrders     RecruitmentOrder[]

  @@unique([x, y])
}

model Building {
  id     String       @id @default(uuid())
  name   BuildingName
  level  Int          @default(0)

  cityId String
  city   City   @relation(fields: [cityId], references: [id])

  @@unique([cityId, name])
}

model BuildingUpgradeOrder {
  id           String       @id @default(uuid())
  buildingName BuildingName
  startAt      DateTime
  finishAt     DateTime
  jobId        String?

  cityId String
  city   City   @relation(fields: [cityId], references: [id])
}

model RecruitmentOrder {
  id       String   @id @default(uuid())
  unitName UnitName
  quantity Int
  startAt  DateTime
  finishAt DateTime
  jobId    String?

  cityId String
  city   City   @relation(fields: [cityId], references: [id])
}

model Unit {
  id       String       @id @default(uuid())
  name     UnitName
  category UnitCategory
  quantity Int          @default(0)

  cityId String
  city   City   @relation(fields: [cityId], references: [id])

  @@unique([cityId, name])
}

model Command {
  id          String        @id @default(uuid())
  type        CommandType
  status      CommandStatus @default(TRAVELING)
  departureAt DateTime      @default(now())
  arrivalAt   DateTime

  // resurse trimise (RESOURCES) sau furate (ATTACK return)
  resourceMoney  Float @default(0)
  resourceEnergy Float @default(0)
  resourceAmmo   Float @default(0)

  // raport de lupta (completat dupa sosire, pentru ATTACK)
  report Json?

  // Fiecare parte isi poate "sterge" raportul (ascunde din lista).
  // Cand ambele sunt true, raportul e invizibil pentru toata lumea.
  reportHiddenByAttacker Boolean @default(false)
  reportHiddenByDefender Boolean @default(false)

  fromCityId String
  fromCity   City   @relation("CommandFrom", fields: [fromCityId], references: [id])

  toCityId String
  toCity   City   @relation("CommandTo", fields: [toCityId], references: [id])

  units CommandUnit[]
}

model CommandUnit {
  id       String   @id @default(uuid())
  name     UnitName
  quantity Int

  commandId String
  command   Command @relation(fields: [commandId], references: [id])

  @@unique([commandId, name])
}
