{
  "name": "server",
  "version": "1.0.0",
  "description": "",
  "main": "index.js",
  "scripts": {
    "dev": "tsx watch src/app.ts",
    "build": "tsc",
    "start": "node dist/app.js",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "db:url": "DOTENV_CONFIG_QUIET=true node -e \"require('dotenv').config(); const e=process.env; console.log('postgresql://'+e.DATABASE_USER+':'+encodeURIComponent(e.DATABASE_PASSWORD)+'@'+e.DATABASE_HOST+':'+(e.DATABASE_PORT||5432)+'/'+e.DATABASE_NAME+'?connection_limit='+(e.DATABASE_CONNECTION_LIMIT||10))\"",
    "db:migrate": "DATABASE_URL=$(npm run db:url --silent) npx prisma migrate dev",
    "db:reset": "DATABASE_URL=$(npm run db:url --silent) npx prisma migrate reset",
    "db:generate": "DATABASE_URL=$(npm run db:url --silent) npx prisma generate"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "type": "commonjs",
  "dependencies": {
    "@prisma/client": "^5.22.0",
    "@types/multer": "^2.1.0",
    "bcrypt": "^6.0.0",
    "bullmq": "^5.71.1",
    "cors": "^2.8.6",
    "dotenv": "^17.3.1",
    "express": "^5.2.1",
    "ioredis": "^5.10.1",
    "jsonwebtoken": "^9.0.3",
    "multer": "^2.1.1",
    "prisma": "^5.22.0",
    "socket.io": "^4.8.3",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@types/bcrypt": "^6.0.0",
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.6",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/node": "^25.5.0",
    "@vitest/coverage-v8": "^4.1.9",
    "tsx": "^4.21.0",
    "typescript": "^6.0.2",
    "vitest": "^4.1.9"
  }
}
